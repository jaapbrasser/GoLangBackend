# ─── GitHub ───────────────────────────────────────────────────────────────────
# A GitHub Personal Access Token (classic) or fine-grained token.
# Required scopes: repo (for private repos) or public_repo (for public only).
# Never commit the real value — use a secrets manager in production.
GITHUB_TOKEN=ghp_your_token_here

# ─── Internal API auth ────────────────────────────────────────────────────────
# Any callers of this service must supply this key in the X-API-Key header.
# Generate a strong random value: openssl rand -hex 32
API_KEY=change_me_to_a_strong_random_secret

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
